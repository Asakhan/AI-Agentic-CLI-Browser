# AI Agentic CLI Browser 환경 변수 예시
# 이 파일을 복사해 .env 로 만들거나, `python setup_env.py` 를 실행하세요.
#   cp .env.example .env

# Anthropic Claude API 키 (필수). https://console.anthropic.com 에서 발급.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 사용할 Claude 모델 (선택, 기본값: claude-sonnet-4-6)
# AI_BROWSER_MODEL=claude-sonnet-4-6

# 다운로드 저장 디렉터리 (선택, 기본값: ./downloads)
# AI_BROWSER_DOWNLOAD_DIR=./downloads

# 헤드리스 모드 (선택, 기본값: true). 로컬 Chromium에서만 의미 있음. 창을 보려면 false.
# AI_BROWSER_HEADLESS=true

# 최대 탐색 스텝 수 (선택, 기본값: 25)
# AI_BROWSER_MAX_STEPS=25

# Lightpanda 등 CDP 엔드포인트 (선택, 권장). 지정 시 해당 서버에 접속한다.
# Zig 기반 초경량 브라우저로 Chrome 대비 메모리 ~16배 적고 ~9배 빠르다.
#   먼저 실행: lightpanda serve --host 127.0.0.1 --port 9222
# 미지정 시 Playwright 내장 Chromium으로 폴백.
# AI_BROWSER_CDP_URL=ws://127.0.0.1:9222
